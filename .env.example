# ═══════════════════════════════════════════════════════
# APRICA - Environment Variables
# Copy this to .env and fill in your API keys
# ═══════════════════════════════════════════════════════

# ── OpenAI (GPT-4o + Whisper + TTS) ──────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── ElevenLabs (African Voice Synthesis) ─────────────
# Get from: https://elevenlabs.io/app/speech-synthesis
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ── Google Cloud Translate ────────────────────────────
# Download service account JSON from Google Cloud Console
GOOGLE_APPLICATION_CREDENTIALS=google_key.json

# ── ElevenLabs Voice IDs (Optional - customize voices) ─
# Find voice IDs at: https://elevenlabs.io/app/voice-library
EL_NIGERIAN_MALE=pNInz6obpgDQGcFmaJgB
EL_NIGERIAN_FEMALE=EXAVITQu4vr4xnSDxMaL
EL_KENYAN_MALE=VR6AewLTigWG4xSOukaG
EL_KENYAN_FEMALE=pFZP5JQG7iQjIQuC4Bku
EL_BRITISH_MALE=onwK4e9ZLuTAKqWW03F9
EL_BRITISH_FEMALE=MF3mGyEYCl7XYWbV9V6O
EL_AMERICAN_MALE=ErXwobaYiN019PkySvjV
